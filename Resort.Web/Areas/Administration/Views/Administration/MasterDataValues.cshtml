@model List<Resort.Model.Models.MasterDataValue>
@{
    ViewData["Title"] = "Giá trị danh mục";
    var key = ViewBag.MasterKey as Resort.Model.Models.MasterDataKey;
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" asp-area="">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Quản trị</a></li>
            <li class="breadcrumb-item active">@key?.Key</li>
        </ol>
    </nav>
}

<div class="py-3">
    <div class="page-header d-flex justify-content-between align-items-center">
        <h4 class="mb-0"><i class="bi bi-list-ul me-2"></i>Danh mục: @key?.Key</h4>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Quay lại
        </a>
    </div>

    <div class="row g-3">
        <!-- Value list -->
        <div class="col-md-7">
            <div class="card">
                <div class="card-header fw-semibold">Danh sách giá trị</div>
                <div class="card-body p-0">
                    <table class="table table-sm align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Giá trị</th>
                                <th>Mô tả</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in Model)
                            {
                                <tr>
                                    <td class="text-muted">@v.DisplayOrder</td>
                                    <td class="fw-medium">@v.Value</td>
                                    <td class="text-muted small">@v.Description</td>
                                    <td>
                                        <span class="badge @(v.IsActive ? "bg-success" : "bg-secondary")">
                                            @(v.IsActive ? "Hoạt động" : "Tắt")
                                        </span>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Any())
                            {
                                <tr><td colspan="4" class="text-center text-muted py-3">Chưa có giá trị nào</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Add value form -->
        <div class="col-md-5">
            <div class="card">
                <div class="card-header fw-semibold"><i class="bi bi-plus-circle me-2"></i>Thêm giá trị mới</div>
                <div class="card-body">
                    <form asp-action="AddValue" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="MasterDataKeyId" value="@key?.Id" />
                        <div class="mb-3">
                            <label class="form-label">Giá trị <span class="text-danger">*</span></label>
                            <input name="Value" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Mô tả</label>
                            <input name="Description" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Thứ tự hiển thị</label>
                            <input name="DisplayOrder" type="number" class="form-control" value="@(Model.Count + 1)" />
                        </div>
                        <div class="form-check mb-3">
                            <input name="IsActive" class="form-check-input" type="checkbox" value="true" checked />
                            <label class="form-check-label">Hoạt động</label>
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="bi bi-floppy me-1"></i>Thêm
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
