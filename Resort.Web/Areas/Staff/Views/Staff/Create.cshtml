@model Resort.Web.Areas.Staff.Controllers.StaffMember
@{
    ViewData["Title"] = "Thêm nhân viên";
    var departments = ViewBag.Departments as List<string> ?? new List<string>();
    var positions   = ViewBag.Positions   as List<string> ?? new List<string>();
    var shifts      = ViewBag.Shifts      as List<string> ?? new List<string>();
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" asp-area="">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Nhân viên</a></li>
            <li class="breadcrumb-item active">Thêm mới</li>
        </ol>
    </nav>
}

<div class="py-3">
    <div class="page-header">
        <h4><i class="bi bi-person-plus me-2"></i>Thêm nhân viên</h4>
    </div>

    <div class="card" style="max-width:700px">
        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="Code" class="form-label">Mã NV <span class="text-danger">*</span></label>
                        <input asp-for="Code" class="form-control" placeholder="NV001" />
                        <span asp-validation-for="Code" class="text-danger small"></span>
                    </div>
                    <div class="col-md-8">
                        <label asp-for="FullName" class="form-label">Họ và tên <span class="text-danger">*</span></label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="IdCard" class="form-label">CCCD</label>
                        <input asp-for="IdCard" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Gender" class="form-label">Giới tính</label>
                        <select asp-for="Gender" class="form-select">
                            <option value="Nam">Nam</option>
                            <option value="Nữ">Nữ</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="DateOfBirth" class="form-label">Ngày sinh</label>
                        <input asp-for="DateOfBirth" class="form-control" type="date" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Department" class="form-label">Bộ phận <span class="text-danger">*</span></label>
                        <select asp-for="Department" class="form-select">
                            <option value="">-- Chọn bộ phận --</option>
                            @foreach (var d in departments)
                            {
                                <option value="@d">@d</option>
                            }
                        </select>
                        <span asp-validation-for="Department" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Position" class="form-label">Chức vụ <span class="text-danger">*</span></label>
                        <select asp-for="Position" class="form-select">
                            <option value="">-- Chọn chức vụ --</option>
                            @foreach (var p in positions)
                            {
                                <option value="@p">@p</option>
                            }
                        </select>
                        <span asp-validation-for="Position" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Phone" class="form-label">Điện thoại</label>
                        <input asp-for="Phone" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" type="email" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Salary" class="form-label">Lương (VNĐ)</label>
                        <input asp-for="Salary" class="form-control" type="number" min="0" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Shift" class="form-label">Ca làm việc</label>
                        <select asp-for="Shift" class="form-select">
                            <option value="">-- Chọn ca --</option>
                            @foreach (var s in shifts)
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-floppy me-1"></i>Lưu
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
