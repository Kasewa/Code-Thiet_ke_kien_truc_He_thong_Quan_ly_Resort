@model List<Resort.Model.Models.Service>
@{
    ViewData["Title"] = "Quản lý dịch vụ";
    var serviceTypes = ViewBag.ServiceTypes as List<string> ?? new();
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" asp-area="">Dashboard</a></li>
            <li class="breadcrumb-item active">Dịch vụ</li>
        </ol>
    </nav>
}

<div class="py-3">
    <div class="page-header d-flex justify-content-between align-items-center">
        <h4 class="mb-0"><i class="bi bi-cup-straw me-2"></i>Quản lý dịch vụ</h4>
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Thêm dịch vụ</a>
    </div>

    <!-- Filter -->
    <div class="card mb-3">
        <div class="card-body py-2">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-auto">
                    <select name="type" class="form-select form-select-sm">
                        <option value="">-- Tất cả loại --</option>
                        @foreach (var t in serviceTypes)
                        {
                            <option value="@t" selected="@(ViewBag.FilterType == t)">@t</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-funnel me-1"></i>Lọc</button>
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary ms-1">Xóa lọc</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Mã DV</th>
                        <th>Tên dịch vụ</th>
                        <th>Loại</th>
                        <th class="text-end">Đơn giá</th>
                        <th>Đơn vị</th>
                        <th>Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td><span class="fw-medium">@s.Code</span></td>
                            <td>@s.Name</td>
                            <td><span class="badge bg-secondary">@s.ServiceType</span></td>
                            <td class="text-end">@s.Price.ToString("N0") ₫</td>
                            <td>@s.Unit</td>
                            <td>
                                <span class="badge @(s.IsActive ? "bg-success" : "bg-secondary")">
                                    @(s.IsActive ? "Hoạt động" : "Tạm ngưng")
                                </span>
                            </td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-outline-warning me-1"><i class="bi bi-pencil"></i></a>
                                <form asp-action="ToggleStatus" asp-route-id="@s.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-secondary me-1" title="@(s.IsActive ? "Tạm ngưng" : "Kích hoạt")">
                                        <i class="bi @(s.IsActive ? "bi-pause" : "bi-play")"></i>
                                    </button>
                                </form>
                                <form asp-action="Delete" asp-route-id="@s.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="button" class="btn btn-sm btn-outline-danger"
                                            onclick="confirmDelete(this.closest('form'), 'Xóa dịch vụ @s.Name?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">Không có dữ liệu</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
