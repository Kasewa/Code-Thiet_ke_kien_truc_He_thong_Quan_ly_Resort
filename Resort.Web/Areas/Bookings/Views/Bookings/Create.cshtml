@model Resort.Model.Models.Booking
@{
    ViewData["Title"] = "Đặt phòng mới";
    var guests = ViewBag.Guests as List<Resort.Model.Models.Guest> ?? new();
    var rooms  = ViewBag.Rooms  as List<Resort.Model.Models.Room>  ?? new();
}

@section Breadcrumb {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" asp-area="">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Đặt phòng</a></li>
            <li class="breadcrumb-item active">Tạo mới</li>
        </ol>
    </nav>
}

<div class="py-3">
    <div class="page-header">
        <h4><i class="bi bi-calendar-plus me-2"></i>Đặt phòng mới</h4>
    </div>

    <div class="card" style="max-width:680px">
        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Code" class="form-label">Mã đặt phòng <span class="text-danger">*</span></label>
                        <input asp-for="Code" class="form-control" placeholder="DP001" />
                        <span asp-validation-for="Code" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="NumberOfGuests" class="form-label">Số lượng khách</label>
                        <input asp-for="NumberOfGuests" class="form-control" type="number" min="1" />
                    </div>
                    <div class="col-12">
                        <label asp-for="GuestId" class="form-label">Khách hàng <span class="text-danger">*</span></label>
                        <select asp-for="GuestId" class="form-select">
                            <option value="">-- Chọn khách --</option>
                            @foreach (var g in guests)
                            {
                                <option value="@g.Id">@g.Code — @g.FullName (@g.Phone)</option>
                            }
                        </select>
                        <span asp-validation-for="GuestId" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="RoomId" class="form-label">Phòng <span class="text-danger">*</span></label>
                        <select asp-for="RoomId" class="form-select">
                            <option value="">-- Chọn phòng trống --</option>
                            @foreach (var r in rooms)
                            {
                                <option value="@r.Id">@r.Code — @r.Name (@r.RoomType) — @r.PricePerNight.ToString("N0") ₫/đêm</option>
                            }
                        </select>
                        <span asp-validation-for="RoomId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="CheckInDate" class="form-label">Ngày check-in <span class="text-danger">*</span></label>
                        <input asp-for="CheckInDate" class="form-control" type="date"
                               value="@Model.CheckInDate.ToString("yyyy-MM-dd")" />
                        <span asp-validation-for="CheckInDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="CheckOutDate" class="form-label">Ngày check-out <span class="text-danger">*</span></label>
                        <input asp-for="CheckOutDate" class="form-control" type="date"
                               value="@Model.CheckOutDate.ToString("yyyy-MM-dd")" />
                        <span asp-validation-for="CheckOutDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Deposit" class="form-label">Tiền đặt cọc (VNĐ)</label>
                        <input asp-for="Deposit" class="form-control" type="number" min="0" />
                    </div>
                    <div class="col-12">
                        <label asp-for="Notes" class="form-label">Ghi chú</label>
                        <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-floppy me-1"></i>Tạo đặt phòng
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
